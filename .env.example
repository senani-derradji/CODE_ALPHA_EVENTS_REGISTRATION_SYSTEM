# Copy this to .env and fill in your values

# Required — must be at least 32 characters; generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# SQLite (dev) or PostgreSQL (prod)
DATABASE_URL=sqlite:///./ACCESS.db
# DATABASE_URL=postgresql://eventuser:eventpass@db:5432/eventdb

# Redis for distributed rate limiting (optional; falls back to in-memory)
REDIS_URL=redis://redis:6379/0

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=72

# OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback
MICROSOFT_TENANT_ID=common

FRONTEND_URL=http://localhost:3000

RATE_LIMIT_AUTH=10
RATE_LIMIT_API=100
